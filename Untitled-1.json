    "jsx_code": "import React from 'react'\nimport { Form, Row, Col } from 'antd'\nimport FormBlockPreview from '@/form-flast/FormBlockPreview'\nimport FormInput from '@/form-flast/FormInput'\nimport FormInputNumber from '@/form-flast/FormInputNumber'\n\nconst FormBlockPreview = ({ title, children }) => {\n  return (\n    <div style={{ border: '1px dashed #d9d9d9', background: '#fff', borderRadius: 6, padding: 16 }}>\n      <div style={{ fontWeight: 600, marginBottom: 4 }}>{title || 'Block'}</div>\n      {children}\n    </div>\n  )\n}\n\nconst HoSoNhanVien = () => {\n  const [form] = Form.useForm()\n  return (\n    <Form form={form} layout=\"vertical\" onFinish={values => console.log(values)}>\n      <Row gutter={[16, 0]}>\n        <Col span={12}>\n          <FormBlockPreview\n            name=\"thong_tin_chung\"\n            title=\"Thông tin chung\"\n          >\n            <Row gutter={[16, 0]}>\n              <Col span={24}>\n                <FormInput\n                  name=\"ho_va_ten\"\n                  label=\"Họ và Tên\"\n                />\n              </Col>\n            </Row>\n          </FormBlockPreview>\n        </Col>\n        <Col span={12}>\n          <FormBlockPreview\n            name=\"thong_tin_chi_tiet\"\n            title=\"Thong tin chi tiết\"\n          >\n            <Row gutter={[16, 0]}>\n              <Col span={24}>\n                <FormInput\n                  name=\"dia_chi\"\n                  label=\"Địa chỉ\"\n                />\n              </Col>\n              <Col span={24}>\n                <FormInput\n                  name=\"que_quan\"\n                  label=\"Quê quán\"\n                />\n              </Col>\n            </Row>\n          </FormBlockPreview>\n        </Col>\n        <Col span={24}>\n          <FormBlockPreview\n            name=\"cong_viec\"\n            title=\"Công việc\"\n          >\n            <Row gutter={[16, 0]}>\n              <Col span={12}>\n                <FormInput\n                  name=\"ten_cong_ty\"\n                  label=\"Tên công ty\"\n                />\n              </Col>\n              <Col span={12}>\n                <FormInputNumber\n                  name=\"nam_thanh_lap\"\n                  label=\"Năm thành lập\"\n                  min={0}\n                  style={{ width: '100%' }}\n                />\n              </Col>\n            </Row>\n          </FormBlockPreview>\n        </Col>\n      </Row>\n    </Form>\n  )\n}\n\nexport default HoSoNhanVien"
